/* SwiftVM Dynamic Linker Configuration Header */
#ifndef SWIFTVM_LINKER_CONFIG_H
#define SWIFTVM_LINKER_CONFIG_H

/* Version information */
#define SWIFTVM_LINKER_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SWIFTVM_LINKER_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SWIFTVM_LINKER_VERSION_PATCH @PROJECT_VERSION_PATCH@

/* Host architecture */
#define SWIFTVM_HOST_ARCH "@CMAKE_SYSTEM_PROCESSOR@"

/* Build configuration */
#cmakedefine BUILD_STANDALONE_LINKER
#cmakedefine BUILD_LINKER_TESTS

/* Feature flags */
#define SWIFTVM_GUEST_SUPPORT 1
#define SWIFTVM_BRIDGE_SUPPORT 1
#define SWIFTVM_SYMBOL_CACHING 1

/* Path configuration */
#define SWIFTVM_INSTALL_PREFIX "@CMAKE_INSTALL_PREFIX@"
#define SWIFTVM_LIB_DIR "@CMAKE_INSTALL_PREFIX@/lib"
#define SWIFTVM_INCLUDE_DIR "@CMAKE_INSTALL_PREFIX@/include"

/* Performance tuning */
#define SWIFTVM_DEFAULT_CACHE_SIZE 10000
#define SWIFTVM_DEFAULT_BRIDGE_CACHE_SIZE 1000

/* Debugging */
#cmakedefine SWIFTVM_DEBUG_MODE
#cmakedefine SWIFTVM_VERBOSE_LOGGING

/* Architecture-specific settings */
#if defined(__x86_64__) || defined(_M_X64)
    #define SWIFTVM_HOST_X86_64 1
    #define SWIFTVM_BRIDGE_AVAILABLE 1
#elif defined(__aarch64__) || defined(_M_ARM64)
    #define SWIFTVM_HOST_ARM64 1
    #define SWIFTVM_BRIDGE_AVAILABLE 1
#elif defined(__riscv) && (__riscv_xlen == 64)
    #define SWIFTVM_HOST_RISCV64 1
    #define SWIFTVM_BRIDGE_AVAILABLE 1
#else
    #define SWIFTVM_BRIDGE_AVAILABLE 0
#endif

/* Critical system libraries that must use host architecture */
#define SWIFTVM_CRITICAL_LIBS \
    "libc.so", "libpthread.so", "libm.so", "libdl.so", "librt.so", "ld-linux"

#endif /* SWIFTVM_LINKER_CONFIG_H */